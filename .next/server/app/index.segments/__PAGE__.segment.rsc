25:["$","$L2","1271",{"href":"/news/articles/the-real-measure-of-military-success","className":"group flex flex-col gap-2 rounded","aria-label":"view [object Object] articles","children":[["$","div",null,{"className":"flex gap-2","children":["$","$L3",null,{"src":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/4c3920e236954b6f86ae774b59048b19.jpg","alt":"THE REAL MEASURE OF MILITARY SUCCESS","parentClassName":"w-full max-w-full sm:max-w-[250px] lg:max-w-[300px] h-[200px]"}]}],["$","h2",null,{"className":"font-semibold group-hover:text-primary  rounded transition-all duration-150 ease-in-out","children":"THE REAL MEASURE OF MILITARY SUCCESS"}],["$","div",null,{"className":"","children":[["$","p",null,{"className":"w-full text-sm text-light h-15 overflow-hidden line-clamp-3","children":"The human aspect of every military operation is inescapable. Behind every strategic calculation is a soldier who is ready to face extraordinary peril in the service of the Republic. They deserve recognition for their courage that is timely, unambiguous and entirely free from political calculation."}],["$","p",null,{"className":"font-semibold text-xs text-primary mt-1","children":"EDITORIAL"}]]}]]}]
