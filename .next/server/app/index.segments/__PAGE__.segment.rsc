1e:["$","$L2","1278",{"href":"/news/articles/the-tragedy-of-indian-law-and-order","className":"group flex flex-col gap-2 rounded","aria-label":"view [object Object] articles","children":[["$","div",null,{"className":"flex gap-2","children":["$","$L3",null,{"src":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/e28e25bcaa18423b94618187e7455d88.jpg","alt":"THE TRAGEDY OF INDIAN LAW AND ORDER","parentClassName":"w-full max-w-full sm:max-w-[250px] lg:max-w-[300px] h-[200px]"}]}],["$","h2",null,{"className":"font-semibold group-hover:text-primary  rounded transition-all duration-150 ease-in-out","children":"THE TRAGEDY OF INDIAN LAW AND ORDER"}],["$","div",null,{"className":"","children":[["$","p",null,{"className":"w-full text-sm text-light h-15 overflow-hidden line-clamp-3","children":"The upcoming trial now takes on huge constitutional importance. Filing of a chargesheet cannot be equated with proving of guilt. The hallmark of democratic societies is that every charge, no matter how emotionally charged or politically sensitive it may be, is put through the paces of an independent judiciary. Evidence must be subject to cross-examination, procedural safeguards must be complied with, and every accused person is entitled to a fair hearing."}],["$","p",null,{"className":"font-semibold text-xs text-primary mt-1","children":"POLITICS"}]]}]]}]
