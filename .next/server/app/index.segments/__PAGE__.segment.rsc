-full sm:max-w-[250px] lg:max-w-[300px] h-[200px]"}]}],["$","h2",null,{"className":"font-semibold group-hover:text-primary  rounded transition-all duration-150 ease-in-out","children":"SURGING GST RECEIPTS DEMAND CAUTION, NOT CELEBRATION"}],["$","div",null,{"className":"","children":[["$","p",null,{"className":"w-full text-sm text-light h-15 overflow-hidden line-clamp-3","children":"Policymakers therefore need to differentiate between temporary statistical gains and sustainable economic strength. The continuing complexities of the regime of the GST deserve, likewise, close attention."}],["$","p",null,{"className":"font-semibold text-xs text-primary mt-1","children":"EDITORIAL"}]]}]]}],["$","$L2","1280",{"href":"/news/articles/when-the-erosion-of-authority-becomes-unreversible","className":"group flex flex-col gap-2 rounded","aria-label":"view [object Object] articles","children":[["$","div",null,{"className":"flex gap-2","children":["$","$L3",null,{"src":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/cf7e8cc0a63c44988f51ce6423344b92.jpg","alt":"WHEN THE EROSION OF AUTHORITY BECOMES UNREVERSIBLE","parentClassName":"w-full max-w-full sm:max-w-[250px] lg:max-w-[300px] h-[200px]"}]}],["$","h2",null,{"className":"font-semibold group-hover:text-primary  rounded transition-all duration-150 ease-in-out","children":"WHEN THE EROSION OF AUTHORITY BECOMES UNREVERSIBLE"}],["$","div",null,{"className":"","children":[["$","p",null,{"className":"w-full text-sm text-light h-15 overflow-hidden line-clamp-3","children":"the crisis the Trinamool Congress faces today appears to be of a different kind, not just because it may lose political ground, but also because the very basis of its power appears to be eroding from within. The fall of a ruling dispensation normally begins with administrative fatigue, public resentment or electoral reverses. It is unique in the current situation that the challenge is more than a standard anti-incumbency."}],"$L1c"]}]]}],"$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26"]}]]}]
18:["$","div",null,{"className":"w-full lg:w-[40%] flex flex-row lg:flex-col gap-10 flex-wrap lg:flex-nowrap","children":[["$","div",null,{"className":"pl-0 lg:pl-5","children":[["$","$L27",null,{"moduleIds":["4127493859067673808"]}],["$","$L28",null,{}]]}],["$","div",null,{"className":"pl-0 lg:pl-5","children":[["$","$L27",null,{"moduleIds":["17860036144349579950"]}],["$","$L29",null,{}]]}],["$","div",null,{"className":"pl-0 lg:pl-5","children":[["$","$L27",null,{"moduleIds":["13161253814373077780"]}],["$","$L2a",null,{}]]}],["$","div",null,{"className":"grid grid-cols-1 sm:grid-cols-2 gap-x-5 gap-y-10","children":[["$","$L2b","21",{"category":{"id":21,"created_at":"2026-06-01T19:14:53.315555+05:30","updated_at":"2026-06-01T19:14:53.315595+05:30","name":"Education","slug":"education"},"categoryArticles":[{"id":1210,"title":"BUILDING THE FUTURE OF INDIA","slug":"building-the-future-of-india","summary":"There is a growing desire to encourage students to investigate different fields of knowledge and to go beyond the boundaries of accepted academic disciplines.","category_name":"Education","banner_image":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/355385d4ce2244d1831c198c4d3a5d08.jpg","category":21,"author":"By LNH","published_at":"2026-06-13T19:10:45.563268+05:30"}]}],["$","$L2b","20",{"category":{"id":20,"created_at":"2026-06-01T11:49:04.674581+05:30","updated_at":"2026-06-01T11:49:04.674618+05:30","name":"Law","slug":"law"},"categoryArticles":[{"id":1178,"title":"The Supreme Court gets 5 new judges, the President approves the appointment","slug":"the-supreme-court-gets-5-new-judges-the-president-approves-the-appointment","summary":"Five new judges have been appointed to the Supreme Court, a fact confirmed by the Union Ministry of Law. Earlier, on May 5, the Union Cabinet had approved a proposal to increase the number of judges in the Supreme Court from 33 to 37.","category_name":"Law","banner_image":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/9ff505e7db96428b92b79116cddc8f5d.jfif","category":20,"author":"By LNH","published_at":"2026-06-01T12:19:43.883791+05:30"}]}],["$","$L2b","19",{"category":{"id":19,"created_at":"2026-05-19T20:12:48.678981+05:30","updated_at":"2026-05-19T20:12:48.679018+05:30","name":"SPRITUAL TREE","slug":"spritual-tree"},"categoryArticles":[{"id":1279,"title":"KARMA IS ABOVE EVERYTHING","slug":"karma-is-above-everything","summary":"It is a philosophy that requires accountability before it offers transformation. Modern society has fallen into the bad habit of attributing success to luck and adversity to circumstance. This perspective breeds helplessness and excuses people from accountability. The Buddhist perspective on karma tells a very different story.","category_name":"SPRITUAL TREE","banner_image":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/ab2fd050477d4591a4d8971068fde42d.jpg","category":19,"author":"By Anandi Mishra","published_at":"2026-07-07T17:40:06.241290+05:30"},{"id":1255,"title":"BOUND BY GRIEF","slug":"bound-by-grief","summary":"A country that can face up to its failures, its tragedies and its periods of collective anguish, displays a much greater resilience than one that chooses to take refuge in selective memory.","category_name":"SPRITUAL TREE","banner_image":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/06bbac90c446488e8941db49b7074225.jpg","category":19,"author":"By Dr. Kirti","published_at":"2026-06-30T20:33:50.683549+05:30"},{"id":1253,"title":"THE COURAGE TO LIVE ONE’S OWN TRUTH","slug":"the-courage-to-live-ones-own-truth","summary":"Indian philosophical thought has long recognised that life cannot be reduced merely to compliance with social norms or adherence to prescribed moral codes. There exists a deeper dimension of human existence, one that calls upon each individual to recognise and honour their unique purpose. This inner calling is not a matter of personal whim or fleeting inclination. Rather, it emerges from the deepest layers of conscience, character, and self-understanding.","category_name":"SPRITUAL TREE","banner_image":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/bffcca31a465488cbdb663b1d978bc91.jpg","category":19,"author":"By Shiva Iyer","published_at":"2026-06-29T12:20:29.335447+05:30"},{"id":1205,"title":"A MORAL COMPASS FOR WORLD POLITICS","slug":"a-moral-compass-for-world-politics","summary":"Instead, it widens the definition of those interests. A country cannot be said to prosper truly when its rivers are poisoned, its air is unbreathable, or its natural resources are exhausted.","category_name":"SPRITUAL TREE","banner_image":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/f689409dcfb04ddcbbc56d9f226bed66.png","category":19,"author":"By LNH","published_at":"2026-06-09T17:14:13.854363+05:30"}]}],"$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a"]}]]}]
