23:["$","$L2","1273",{"href":"/news/articles/when-political-parties-fail-to-foster-provincial-statesmen","className":"group flex flex-col gap-2 rounded","aria-label":"view [object Object] articles","children":[["$","div",null,{"className":"flex gap-2","children":["$","$L3",null,{"src":"https://site-bucket.blr1.digitaloceanspaces.com/site-bucket/ef6886db8ace4c9281a0dadf5314cdc7.jpg","alt":"WHEN POLITICAL PARTIES FAIL TO FOSTER PROVINCIAL STATESMEN","parentClassName":"w-full max-w-full sm:max-w-[250px] lg:max-w-[300px] h-[200px]"}]}],["$","h2",null,{"className":"font-semibold group-hover:text-primary  rounded transition-all duration-150 ease-in-out","children":"WHEN POLITICAL PARTIES FAIL TO FOSTER PROVINCIAL STATESMEN"}],["$","div",null,{"className":"","children":[["$","p",null,{"className":"w-full text-sm text-light h-15 overflow-hidden line-clamp-3","children":"Each state has its own history, economic priorities, language identity, and cultural temperament. This kind of diversity needs leaders who claim real legitimacy in their own areas and who can voice local concerns without seeming to be subordinate to remote authority. The decline in the importance of provincial leadership also has an impact on governance."}],["$","p",null,{"className":"font-semibold text-xs text-primary mt-1","children":"POLITICS"}]]}]]}]
